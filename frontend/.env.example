# ─── Backend API ─────────────────────────────────────────────────────────────
# URL of the Django backend origin or API root (no trailing slash).
# Both http://localhost:8000 and http://localhost:8000/api are accepted.
VITE_API_URL=http://localhost:8000

# ─── Firebase Web Push (FCM) ─────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → General → Your apps
# SECURITY: These values identify your Firebase project. Restrict the API key
# in the Firebase Console to your production domain only.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── REQUIRED: Web Push VAPID key ────────────────────────────────────────────
# Get this from:
#   Firebase Console → Project Settings → Cloud Messaging
#   → Web Push certificates → Generate key pair → copy the "Key pair" value
VITE_FIREBASE_VAPID_KEY=
