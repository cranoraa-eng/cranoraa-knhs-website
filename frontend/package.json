{
  "name": "school-portal-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run type-check && vite build",
    "build:with-lint": "npm run lint:errors && npm run type-check && vite build",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext js,jsx,ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:errors": "eslint . --ext js,jsx,ts,tsx --report-unused-disable-directives --quiet",
    "lint:fix": "eslint . --ext js,jsx,ts,tsx --report-unused-disable-directives --max-warnings 0 --fix",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "codemod:fix-substr": "jscodeshift -t ../scripts/codemods/fix-substr.js",
    "codemod:fix-substr:dry": "jscodeshift -t ../scripts/codemods/fix-substr.js --dry",
    "codemod:fix-escape": "jscodeshift -t ../scripts/codemods/fix-escape-unescape.js",
    "codemod:fix-escape:dry": "jscodeshift -t ../scripts/codemods/fix-escape-unescape.js --dry",
    "codemod:fix-html": "jscodeshift -t ../scripts/codemods/fix-html-methods.js",
    "codemod:fix-html:dry": "jscodeshift -t ../scripts/codemods/fix-html-methods.js --dry",
    "codemod:test": "cross-env NODE_PATH=node_modules node ../scripts/codemods/fix-substr.test.js",
    "codemod:test:substr": "cross-env NODE_PATH=node_modules node ../scripts/codemods/fix-substr.test.js",
    "codemod:test:escape": "cross-env NODE_PATH=node_modules node ../scripts/codemods/fix-escape-unescape.test.js",
    "codemod:test:html": "cross-env NODE_PATH=node_modules node ../scripts/codemods/fix-html-methods.test.js"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.10",
    "axios": "^1.6.2",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.40.0",
    "html2canvas": "1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^3.8.1",
    "sweetalert2": "^11.26.24",
    "xlsx": "^0.18.5",
    "xlsx-populate": "^1.21.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "cross-env": "^10.1.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jscodeshift": "^17.3.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.32",
    "prettier": "^3.9.4",
    "tailwindcss": "^3.3.6",
    "typescript": "^6.0.3",
    "vite": "^5.0.8",
    "vitest": "^4.1.9"
  }
}
