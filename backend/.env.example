# Django Settings
DJANGO_SECRET_KEY=your-secret-key
DEBUG=False
ALLOWED_HOSTS=cranoraa-knhs-website-1.onrender.com,localhost

# Database (Supabase PostgreSQL - Use Pooler Port 6543)
DATABASE_URL=postgresql://user:password@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres

# Email Configuration (Gmail)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=KNHS Portal <your-email@gmail.com>

# CORS Settings
CORS_ALLOWED_ORIGINS=https://cranoraa-knhs-website.vercel.app,http://localhost:5173
CSRF_TRUSTED_ORIGINS=https://cranoraa-knhs-website.vercel.app

# Django Axes (Rate Limiting)
AXES_FAILURE_LIMIT=20
AXES_COOLOFF_TIME=30

# Initial Superuser Creation (Production-safe strategy)
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=your-secure-password
