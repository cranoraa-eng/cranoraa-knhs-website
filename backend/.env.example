# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-generate-with-python-secrets
DEBUG=False
ALLOWED_HOSTS=cranoraa-knhs-website-1.onrender.com,localhost,127.0.0.1

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=KNHS Portal <your-email@gmail.com>

# CORS Settings
CORS_ALLOWED_ORIGINS=https://cranoraa-eng-cranoraa-knhs-website.vercel.app,http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=https://cranoraa-eng-cranoraa-knhs-website.vercel.app,http://localhost:5173,http://127.0.0.1:5173

# Django Axes (Rate Limiting)
AXES_FAILURE_LIMIT=20
AXES_COOLOFF_TIME=30

# Supabase Storage Configuration (Required for file uploads)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=profile-pictures

# Mailjet Configuration (Required for emails/OTP)
MAILJET_API_KEY=your-mailjet-api-key
MAILJET_SECRET_KEY=your-mailjet-secret-key
MAILJET_SENDER_EMAIL=noreply@kiwalan-nhs.edu.ph
